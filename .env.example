# WorkLin Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# FIREBASE (Required)
# ============================================
# Get these from: Firebase Console > Project Settings > Your apps > Web app

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=bnex-test.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=bnex-test
VITE_FIREBASE_STORAGE_BUCKET=bnex-test.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# GOOGLE GEMINI AI (Optional - For AI Features)
# ============================================
# Get API key: https://aistudio.google.com/apikey
# Free tier: 60 requests per minute

VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# YJS WEBSOCKET (Optional - For Real-time Collaboration)
# ============================================
# Deploy yjs-server/ on Cloud Run or any Node host
# Use wss:// (secure WebSocket) for production

# VITE_YJS_WEBSOCKET_URL=wss://your-yjs-server-url

# ============================================
# NOTES
# ============================================
# - Firebase Storage is used for image uploads (page covers, profiles)
# - App works without Gemini (no AI features)
# - App works without Yjs (no real-time collaboration)
# - Firebase is required for authentication and data storage
